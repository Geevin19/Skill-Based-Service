PORT=5000
NODE_ENV=development

# Database - update this with your PostgreSQL credentials
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/skillswap

# JWT
JWT_SECRET=skillswap_super_secret_jwt_key_2024
JWT_EXPIRES_IN=7d

# Email (Nodemailer) - update with real credentials to use email features
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Stripe - update with real keys to use payments
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# Frontend URL
CLIENT_URL=http://localhost:5173

# File Upload (10MB)
MAX_FILE_SIZE=10485760
